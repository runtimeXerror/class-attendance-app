# Copy this to .env in the backend folder. Never commit .env to git.

# REQUIRED — generate a random 32+ char string
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# OPTIONAL — for auto-emailing credentials to new admins/teachers
# Use Gmail + App Password (NOT your real Gmail password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=yourname@gmail.com
